PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/voice_calling_india

# Bolna (India Voice Provider)
BOLNA_API_KEY=your_bolna_api_key_here
BOLNA_BASE_URL=https://api.bolna.dev
BOLNA_DEFAULT_PHONE_NUMBER=+911234567890
BOLNA_AVAILABLE_PHONE_NUMBERS=+911234567890

# OpenAI (For booking extraction)
OPENAI_API_KEY=your_openai_api_key_here

# Frontend CORS
FRONTEND_URL=http://localhost:5173

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Webhook
WEBHOOK_SECRET=your_webhook_secret_here
